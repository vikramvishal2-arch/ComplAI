# Copy to .env.production on your EC2 / VPS host

POSTGRES_USER=grc
POSTGRES_PASSWORD=change-me-to-a-long-random-password
POSTGRES_DB=grc_platform

# Public URLs (required for IDAM agent bundles, metadata, and redirects)
# ComplAI Lab on EC2 — HTTPS + /complAI/Lab path (see deploy/ec2-https-lab.sh)
# Use lab.propelreadysolutions.in once DNS A record points to your EC2 IP, or sslip.io for immediate HTTPS:
APP_URL=https://13-233-254-149.sslip.io/complAI/Lab
NEXT_PUBLIC_APP_URL=https://13-233-254-149.sslip.io/complAI/Lab
NEXT_PUBLIC_SITE_URL=https://13-233-254-149.sslip.io/complAI/Lab

# --- Customer demo portal (ComplAI Lab) ---
# Enable login gate + per-customer credentials (see prisma/create-demo-portal-user.ts)
DEMO_PORTAL_ENABLED=true
DEMO_SESSION_SECRET=
# Legacy shared admin password (optional fallback — grants full admin access)
DEMO_ACCESS_PASSWORD=
# Seeded by npm run demo:seed when unset:
DEMO_CUSTOMER_EMAIL=demo.customer@acme-demo.com
DEMO_CUSTOMER_PASSWORD=ComplAI-Demo-2026!
DEMO_ADMIN_EMAIL=admin@propelreadysolutions.in
DEMO_ADMIN_PASSWORD=
NEXT_PUBLIC_DEMO_MODE=true

NEXT_PUBLIC_INTEGRATION_HELP_BASE_URL=https://propelreadysolutions.in/help/integrations

# AI (optional — disable for marketing-only launch)
AI_ENABLED=false
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Contact form — enquiries emailed to tech@propelreadysolutions.in
CONTACT_INQUIRY_TO=tech@propelreadysolutions.in
CONTACT_INQUIRY_FROM="Propel Ready Website <noreply@propelreadysolutions.in>"
# RESEND_API_KEY=re_...
# Or SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS

# Optional integrations
CHRONICLE_ENABLED=false
AWS_MONITOR_ENABLED=false
AZURE_MONITOR_ENABLED=false

# Elasticsearch + Kibana (enable with: docker compose --profile analytics up -d)
ELASTICSEARCH_URL=http://elasticsearch:9200
KIBANA_URL=http://kibana:5601
KIBANA_PUBLIC_URL=https://13-233-254-149.sslip.io:5601
