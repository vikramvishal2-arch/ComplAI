{
  "name": "grc-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:privycore": "npm run dev --prefix privacy-platform",
    "build:privycore": "npm run build --prefix privacy-platform",
    "dev:full": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "node scripts/prisma-generate-safe.mjs",
    "db:up": "docker compose up -d",
    "analytics:up": "powershell -ExecutionPolicy Bypass -File scripts/analytics-up.ps1",
    "docker:start": "powershell -ExecutionPolicy Bypass -File scripts/docker-start.ps1",
    "docker:repair": "powershell -ExecutionPolicy Bypass -File scripts/docker-repair.ps1",
    "analytics:down": "docker compose stop elasticsearch kibana",
    "analytics:reset": "powershell -ExecutionPolicy Bypass -File scripts/analytics-reset.ps1",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push --skip-generate",
    "db:generate": "node scripts/prisma-regenerate.mjs",
    "db:generate:win": "scripts\\prisma-generate.cmd",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-members": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:setup": "prisma db push --skip-generate && tsx prisma/seed.ts",
    "demo:seed": "tsx prisma/demo-seed.ts",
    "demo:reset": "tsx prisma/demo-reset.ts",
    "ill:seed": "tsx prisma/ill-seed.ts",
    "ill:stack": "docker compose -f docker-compose.yml -f services/ill-threat-intel/docker-compose.ill.yml up -d",
    "ill:smoke": "node scripts/ill-pilot-smoke-test.mjs",
    "deploy:prod": "docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build",
    "deploy:prod:down": "docker compose -f docker-compose.prod.yml down",
    "deploy:prod:logs": "docker compose -f docker-compose.prod.yml logs -f app",
    "deploy:prod:seed": "docker compose -f docker-compose.prod.yml --env-file .env.production --profile tools run --rm tools prisma/demo-seed.ts",
    "training:audio:manifest": "tsx scripts/build-training-audio-manifest.ts",
    "training:audio:generate": "npm run training:audio:manifest && powershell -ExecutionPolicy Bypass -File scripts/generate-training-narration.ps1",
    "deck:pptx": "node scripts/generate-complyos-deck.mjs",
    "deck:pdf": "node scripts/generate-complyos-deck-pdf.mjs",
    "deck:customer": "node scripts/generate-complai-customer-deck.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-cloudtrail": "^3.1073.0",
    "@aws-sdk/client-iam": "^3.1073.0",
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/client-sts": "^3.1073.0",
    "@elastic/elasticsearch": "^8.15.0",
    "@prisma/client": "^6.9.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "docx": "^9.7.1",
    "edge-tts": "^1.0.1",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.9",
    "nodemailer": "^9.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.4.0",
    "pptxgenjs": "^4.0.1",
    "prisma": "^6.9.0",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
