generator client {
  provider   = "prisma-client-js"
  // Avoid Windows EPERM on query_engine-windows.dll.node (use standalone binary instead)
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  frameworkActivations FrameworkActivation[]
  controlCompliances   ControlCompliance[]
  controlRemediations  ControlRemediation[]
  controlIssues        ControlIssue[]
  controlEvidence      ControlEvidence[]
  risks                Risk[]
  riskControls         RiskControl[]
  vendors              Vendor[]
  vendorAssessments    VendorAssessment[]
  monitorCheckRuns     MonitorCheckRun[]
  policies             Policy[]
  members              OrganizationMember[]
  programCycles            ProgramCycle[]
  organizationIntegrations OrganizationIntegration[]
  endpointAgents           EndpointAgent[]
  auditEngagements         AuditEngagement[]
  auditPrograms            AuditProgram[]
  auditFindings            AuditFinding[]
  externalReadinessItems   ExternalReadinessItem[]
  auditEvidenceRequests    AuditEvidenceRequest[]
  auditRiskAssessments     AuditRiskAssessment[]
  auditRiskDomains         AuditRiskDomain[]

  @@map("organizations")
}

model OrganizationIntegration {
  id                String    @id @default(cuid())
  organizationId    String    @map("organization_id")
  toolId            String    @map("tool_id")
  domain            String    @default("idam")
  status            String    @default("not_connected")
  accountIdentifier String    @default("") @map("account_identifier")
  adminContact      String    @default("") @map("admin_contact")
  connectionMode    String    @default("api") @map("connection_mode")
  config            Json      @default("{}")
  connectedAt       DateTime? @map("connected_at")
  lastSyncAt        DateTime? @map("last_sync_at")
  notes             String    @default("")
  source            String    @default("manual")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, toolId])
  @@index([organizationId, domain])
  @@map("organization_integrations")
}

model EndpointAgent {
  id                  String    @id @default(cuid())
  organizationId      String    @map("organization_id")
  bundleId            String    @map("bundle_id")
  status              String    @default("pending")
  enrollmentTokenHash String    @map("enrollment_token_hash")
  agentSecretHash     String?   @map("agent_secret_hash")
  hostname            String    @default("")
  platform            String    @default("")
  agentVersion        String    @default("0.1.0") @map("agent_version")
  idamSnapshot        Json      @default("[]") @map("idam_snapshot")
  enrolledAt          DateTime? @map("enrolled_at")
  lastHeartbeatAt     DateTime? @map("last_heartbeat_at")
  expiresAt           DateTime  @map("expires_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([enrollmentTokenHash])
  @@map("endpoint_agents")
}

model FrameworkActivation {
  id              String    @id @default(cuid())
  organizationId  String    @map("organization_id")
  frameworkId     String    @map("framework_id")
  activatedAt     DateTime  @default(now()) @map("activated_at")
  targetAuditDate DateTime? @map("target_audit_date") @db.Date

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, frameworkId])
  @@map("framework_activations")
}

model FrameworkCatalogEntry {
  id          String   @id @default(cuid())
  frameworkId String   @unique @map("framework_id")
  source      String   @default("custom")
  name        String
  shortName   String   @map("short_name")
  description String
  category    String
  region      String   @default("Global")
  version     String   @default("")
  popular     Boolean  @default(false)
  published   Boolean  @default(true)
  tags        Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("framework_catalog_entries")
}

model ControlCompliance {
  id                     String    @id @default(cuid())
  organizationId         String    @map("organization_id")
  controlId              String    @map("control_id")
  status                 String    @default("not_started")
  complianceMethod       String?   @map("compliance_method")
  implementationApproach String    @default("") @map("implementation_approach")
  owner                  String    @default("")
  targetDate             DateTime? @map("target_date") @db.Date
  evidenceNotes          String    @default("") @map("evidence_notes")
  naJustification        String    @default("") @map("na_justification")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, controlId])
  @@index([organizationId])
  @@map("control_compliance")
}

model ControlRemediation {
  id                String   @id @default(cuid())
  organizationId    String   @map("organization_id")
  controlId         String   @map("control_id")
  actions           Json     @default("[]")
  accessConnections Json     @default("[]") @map("access_connections")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, controlId])
  @@index([organizationId])
  @@map("control_remediations")
}

model ControlIssue {
  id               String    @id @default(cuid())
  organizationId   String    @map("organization_id")
  controlId        String    @map("control_id")
  riskId           String?   @map("risk_id")
  title            String
  description      String    @default("")
  severity         String    @default("medium")
  status           String    @default("open")
  raisedBy         String    @default("") @map("raised_by")
  assignee         String    @default("")
  dueDate          DateTime? @map("due_date") @db.Date
  resolutionNotes  String    @default("") @map("resolution_notes")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, controlId])
  @@index([organizationId, riskId])
  @@map("control_issues")
}

model ControlEvidence {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  controlId      String   @map("control_id")
  context        String
  issueId        String?  @map("issue_id")
  fileName       String   @map("file_name")
  originalName   String   @map("original_name")
  mimeType       String   @map("mime_type")
  sizeBytes      Int      @map("size_bytes")
  description    String   @default("")
  storagePath    String   @map("storage_path")
  uploadedAt     DateTime @default(now()) @map("uploaded_at")
  validationVerdict  String?   @map("validation_verdict")
  validationScore    Int?      @map("validation_score")
  validationSummary  String?   @map("validation_summary")
  validationAction   String?   @map("validation_action")
  validatedAt        DateTime? @map("validated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, controlId, context])
  @@map("control_evidence")
}

model Risk {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  controlId      String    @map("control_id")
  title          String
  description    String    @default("")
  category       String    @default("compliance")
  likelihood     String    @default("possible")
  impact         String    @default("moderate")
  riskScore      Int       @default(9) @map("risk_score")
  residualLikelihood String? @map("residual_likelihood")
  residualImpact     String? @map("residual_impact")
  residualRiskScore  Int?    @map("residual_risk_score")
  treatment      String    @default("mitigate")
  status         String    @default("identified")
  owner          String    @default("")
  reviewer       String    @default("")
  approver       String    @default("")
  dueDate        DateTime? @map("due_date") @db.Date
  mitigationPlan String    @default("") @map("mitigation_plan")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  controlMappings RiskControl[]

  @@index([organizationId, controlId])
  @@index([organizationId, status])
  @@map("risks")
}

/// Many-to-many: a risk must map to one or more controls; effectiveness drives auto-issues.
model RiskControl {
  id              String    @id @default(cuid())
  organizationId  String    @map("organization_id")
  riskId          String    @map("risk_id")
  controlId       String    @map("control_id")
  effectiveness   String    @default("not_assessed") // not_assessed | effective | ineffective | failed | non_compliant
  assessmentNotes String    @default("") @map("assessment_notes")
  lastAssessedAt  DateTime? @map("last_assessed_at")
  linkedIssueId   String?   @map("linked_issue_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  risk         Risk         @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@unique([riskId, controlId])
  @@index([organizationId, controlId])
  @@index([organizationId, riskId])
  @@map("risk_controls")
}

model AuditEngagement {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  framework      String   @default("")
  auditor        String   @default("")
  type           String   @default("external") // internal | external
  status         String   @default("planning") // planning | fieldwork | reporting | closed
  startDate      DateTime? @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  readiness      Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type])
  @@index([organizationId, status])
  @@map("audit_engagements")
}

model AuditProgram {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  scope          String   @default("")
  lead           String   @default("")
  status         String   @default("scheduled") // scheduled | in_progress | complete
  startDate      DateTime? @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  coverage       Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@map("audit_programs")
}

model AuditFinding {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  source         String   @default("internal") // internal | external
  engagement     String   @default("")
  severity       String   @default("medium") // critical | high | medium | low
  title          String
  controlRef     String   @default("") @map("control_ref")
  owner          String   @default("")
  status         String   @default("open") // open | in_progress | remediated | accepted
  dueDate        DateTime? @map("due_date") @db.Date
  notes          String   @default("")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, source])
  @@index([organizationId, status])
  @@index([organizationId, controlRef])
  @@map("audit_findings")
}

model ExternalReadinessItem {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  category       String   @default("")
  task           String
  framework      String   @default("")
  owner          String   @default("")
  status         String   @default("not_started") // not_started | in_progress | ready | blocked
  dueDate        DateTime? @map("due_date") @db.Date
  notes          String   @default("")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@map("external_readiness_items")
}

model AuditEvidenceRequest {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  engagement     String   @default("")
  request        String
  controlRef     String   @default("") @map("control_ref")
  assignee       String   @default("")
  status         String   @default("pending") // pending | submitted | accepted | rejected
  dueDate        DateTime? @map("due_date") @db.Date
  notes          String   @default("")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([organizationId, controlRef])
  @@map("audit_evidence_requests")
}

model AuditRiskAssessment {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  area           String
  summary        String   @default("")
  inherentRisk   String   @default("medium") @map("inherent_risk")
  residualRisk   String   @default("medium") @map("residual_risk")
  controlsTested Int      @default(0) @map("controls_tested")
  gapsIdentified Int      @default(0) @map("gaps_identified")
  owner          String   @default("")
  lastReviewed   DateTime? @map("last_reviewed") @db.Date
  controlsInScope Json     @default("[]") @map("controls_in_scope")
  gaps            Json     @default("[]")
  recommendations Json     @default("[]")
  linkedFindingIds Json    @default("[]") @map("linked_finding_ids")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("audit_risk_assessments")
}

model AuditRiskDomain {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  domainKey      String   @map("domain_key")
  name           String
  controlRefs    Json     @default("[]") @map("control_refs")
  owner          String   @default("")
  status         String   @default("not_started")
  identification Json     @default("{}")
  analysis       Json     @default("{}")
  evaluation     Json     @default("{}")
  riskItems      Json     @default("[]") @map("risk_items")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, domainKey])
  @@index([organizationId])
  @@map("audit_risk_domains")
}

model Vendor {
  id                String    @id @default(cuid())
  organizationId    String    @map("organization_id")
  name              String
  description       String    @default("")
  tier              String    @default("medium")
  dataAccess        String    @default("none") @map("data_access")
  status            String    @default("active")
  contactEmail      String    @default("") @map("contact_email")
  website           String    @default("")
  primaryDomain     String    @default("") @map("primary_domain")
  industry          String    @default("")
  inherentRiskScore Int       @default(50) @map("inherent_risk_score")
  aiRiskScore       Int?      @map("ai_risk_score")
  aiRiskSummary     String    @default("") @map("ai_risk_summary")
  securityRating    Int?      @map("security_rating")
  ratingGrade       String    @default("") @map("rating_grade")
  domainScores      Json      @default("{}") @map("domain_scores")
  labels            Json      @default("[]")
  certifications Json      @default("[]")
  breachIntel       Json      @default("{}") @map("breach_intel")
  externalIntel     Json      @default("{}") @map("external_intel")
  lastAssessedAt    DateTime? @map("last_assessed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assessments  VendorAssessment[]

  @@index([organizationId])
  @@map("vendors")
}

model VendorAssessment {
  id                  String    @id @default(cuid())
  organizationId      String    @map("organization_id")
  vendorId            String    @map("vendor_id")
  status              String    @default("draft")
  templateId          String    @default("tprm-standard") @map("template_id")
  templateName        String    @default("TPRM Standard") @map("template_name")
  questionnaireStatus String    @default("internal") @map("questionnaire_status")
  questions           Json      @default("[]")
  responses           Json      @default("[]")
  aiScore             Int?      @map("ai_score")
  aiSummary           String    @default("") @map("ai_summary")
  domainScores        Json      @default("{}") @map("domain_scores")
  gaps                Json      @default("[]")
  findings            Json      @default("[]")
  remediationItems    Json      @default("[]") @map("remediation_items")
  dueDate             DateTime? @map("due_date") @db.Date
  completedAt         DateTime? @map("completed_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor       Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([organizationId, vendorId])
  @@map("vendor_assessments")
}

model MonitorCheckRun {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  provider       String
  status         String   @default("running")
  passed         Int      @default(0)
  failed         Int      @default(0)
  errors         Int      @default(0)
  summary        String   @default("")
  startedAt      DateTime @default(now()) @map("started_at")
  completedAt    DateTime? @map("completed_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  results      MonitorCheckResult[]

  @@index([organizationId, provider])
  @@map("monitor_check_runs")
}

model MonitorCheckResult {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  runId          String   @map("run_id")
  checkId        String   @map("check_id")
  checkName      String   @map("check_name")
  controlId      String?  @map("control_id")
  status         String
  message        String   @default("")
  remediation    String   @default("")
  checkedAt      DateTime @default(now()) @map("checked_at")

  run MonitorCheckRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([organizationId, runId])
  @@index([organizationId, checkId])
  @@map("monitor_check_results")
}

model Policy {
  id               String    @id @default(cuid())
  organizationId   String    @map("organization_id")
  templateId       String?   @map("template_id")
  categoryId       String    @map("category_id")
  title            String
  status           String    @default("draft")
  version          String    @default("1.0")
  owner            String    @default("")
  content          String    @default("")
  source           String    @default("template")
  storagePath      String?   @map("storage_path")
  originalFileName String?   @map("original_file_name")
  mimeType         String?   @map("mime_type")
  isoReference     String    @default("") @map("iso_reference")
  documentType     String    @default("policy") @map("document_type")
  linkedControlIds Json      @default("[]") @map("linked_control_ids")
  controlsSyncedAt DateTime? @map("controls_synced_at")
  approvalMatrix   Json      @default("[]") @map("approval_matrix")
  reviewDate       DateTime? @map("review_date") @db.Date
  approvedAt       DateTime? @map("approved_at")
  standardsReview  Json?     @map("standards_review")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, categoryId])
  @@map("policies")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  email          String
  title          String   @default("")
  department     String   @default("")
  approvalRoles  Json     @default("[]") @map("approval_roles")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId, active])
  @@map("organization_members")
}

model ContactInquiry {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String
  requirement String
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("contact_inquiries")
}

model ThreatIoc {
  id          String    @id @default(cuid())
  iocType     String    @map("ioc_type")
  value       String
  urlHash     String?   @map("url_hash")
  category    String    @default("other")
  confidence  Float     @default(0.9)
  sourceFeed  String    @map("source_feed")
  blacklisted Boolean   @default(true)
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([iocType, value])
  @@index([iocType, value])
  @@index([urlHash])
  @@index([updatedAt])
  @@map("threat_iocs")
}

model ThreatFeed {
  id         String    @id @default(cuid())
  name       String    @unique
  feedType   String    @map("feed_type")
  lastSyncAt DateTime? @map("last_sync_at")
  status     String    @default("active")
  config     Json      @default("{}")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("threat_feeds")
}

model ThreatGatewayAuditLog {
  id         String   @id @default(cuid())
  requestId  String   @map("request_id")
  endpoint   String
  clientId   String?  @map("client_id")
  ip         String?
  url        String?
  statusCode Int      @map("status_code")
  verdict    String?
  latencyMs  Int?     @map("latency_ms")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("threat_gateway_audit_logs")
}

model ProgramCycle {
  id               String    @id @default(cuid())
  organizationId   String    @map("organization_id")
  programType      String    @map("program_type")
  title            String
  description      String    @default("")
  periodStart      DateTime  @map("period_start") @db.Date
  periodEnd        DateTime  @map("period_end") @db.Date
  dueDate          DateTime  @map("due_date") @db.Date
  status           String    @default("upcoming")
  owner            String    @default("")
  lastCompletedAt  DateTime? @map("last_completed_at")
  completedAt      DateTime? @map("completed_at")
  reminderDays     Json      @default("[30, 14, 7]") @map("reminder_days")
  notes            String    @default("")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reminderLogs CycleReminderLog[]

  @@index([organizationId, programType])
  @@index([organizationId, status])
  @@map("program_cycles")
}

model CycleReminderLog {
  id            String   @id @default(cuid())
  cycleId       String   @map("cycle_id")
  channel       String   @default("in_app")
  reminderType  String   @map("reminder_type")
  recipientEmail String  @default("") @map("recipient_email")
  sentAt        DateTime @default(now()) @map("sent_at")
  acknowledged  Boolean  @default(false)
  acknowledgedAt DateTime? @map("acknowledged_at")

  cycle ProgramCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([cycleId, reminderType])
  @@map("cycle_reminder_logs")
}

model DemoPortalAccount {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @default("") @map("display_name")
  role         String   @default("customer")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("demo_portal_accounts")
}

model IllCircuit {
  id            String   @id @default(cuid())
  circuitId     String   @unique @map("circuit_id")
  customerName  String   @map("customer_name")
  nsp           String
  pop           String
  failMode      String   @default("fail_open") @map("fail_mode")
  policyProfile String   @default("standard") @map("policy_profile")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  decisions IllPolicyDecision[]

  @@index([nsp, pop])
  @@map("ill_circuits")
}

model IllPolicyDecision {
  id        String   @id @default(cuid())
  circuitId String   @map("circuit_id")
  srcIp     String   @map("src_ip")
  destIp    String?  @map("dest_ip")
  url       String?
  domain    String?
  verdict   String
  reason    String
  cacheHit  Boolean  @default(false) @map("cache_hit")
  checkedAt DateTime @default(now()) @map("checked_at")

  circuit IllCircuit @relation(fields: [circuitId], references: [circuitId], onDelete: Cascade)

  @@index([circuitId, checkedAt])
  @@map("ill_policy_decisions")
}
