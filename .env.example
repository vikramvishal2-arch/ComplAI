# PostgreSQL (local Docker — see docker-compose.yml)
DATABASE_URL="postgresql://grc:grc_dev_password@localhost:5432/grc_platform?schema=public"

# AI Copilot — pick a provider: openai | ollama | groq
AI_ENABLED=true
AI_PROVIDER=ollama

# --- Option A: Ollama (FREE, local — no API key needed) ---
# 1. Install from https://ollama.com
# 2. Run: ollama pull llama3.2
# 3. Use settings below (defaults work)
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=llama3.2
# OPENAI_API_KEY not required for Ollama

# --- Option B: Groq (FREE tier — get key at https://console.groq.com) ---
# AI_PROVIDER=groq
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.1-8b-instant

# --- Option C: OpenAI (paid API — ChatGPT Go subscription does NOT include this) ---
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Training video narration (natural voice via OpenAI TTS when OPENAI_API_KEY is set)
# TRAINING_TTS_VOICE=nova
# TRAINING_TTS_MODEL=tts-1
# Bundled narration (no API key): npm run training:audio:generate

# Google Chronicle / SecOps (optional)
CHRONICLE_ENABLED=false
CHRONICLE_GCP_PROJECT_ID=
CHRONICLE_INSTANCE=
CHRONICLE_REGION=us
GOOGLE_APPLICATION_CREDENTIALS=

# --- Contact form email (submissions go to tech@propelreadysolutions.in) ---
CONTACT_INQUIRY_TO=tech@propelreadysolutions.in
CONTACT_INQUIRY_FROM="Propel Ready Website <noreply@propelreadysolutions.in>"
# Uses FormSubmit relay by default when Resend/SMTP are not set (first email needs inbox activation).
# Set to false to require RESEND_API_KEY or SMTP_HOST instead.
# CONTACT_USE_FORMSUBMIT=false

# Option A: Resend (https://resend.com) — verify your domain, then set API key
# RESEND_API_KEY=re_...

# Option B: SMTP (e.g. Google Workspace / Zoho / Mailtrap for localhost)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="ComplAI GRC <noreply@propelreadysolutions.in>"
# Redirect all automated mail (TPRM, policy approvals, risk notifications) while testing locally:
# EMAIL_OVERRIDE_TO=you@example.com
# Optional internal notify when a vendor assessment is scored:
# TPRM_NOTIFY_EMAIL=grc-team@example.com
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# Risk owner/reviewer/approver emails use the shared mailer above (no RISK_NOTIFY_* vars).

# --- AWS lab monitoring (read-only IAM user or role) ---
AWS_MONITOR_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Azure lab monitoring (service principal with Reader + Security Reader) ---
AZURE_MONITOR_ENABLED=false
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Customer demo (optional — local walkthroughs skip password when unset) ---
# DEMO_ACCESS_PASSWORD=
# NEXT_PUBLIC_DEMO_MODE=true

# --- Elasticsearch + Kibana (docker-compose.yml spins these up) ---
ELASTICSEARCH_URL=http://localhost:9200
KIBANA_URL=http://localhost:5601

# --- TPRM / External Intelligence Integration Service ---
# Pipeline: ComplAI → HTTPS + API key → provider JSON → validation → Postgres → Elasticsearch
# Refresh from vendor detail: POST /api/vendors/:id/refresh-intelligence
# Search correlated findings: GET /api/vendors/intel/search?q=
#
# Shodan — internet-facing hosts/ports/CVEs for vendor hostname
# https://account.shodan.io/
# SHODAN_API_KEY=
#
# Censys Platform — attack-surface (hosts/ports/software) via Personal Access Token (Bearer)
# https://platform.censys.io → API Access. Optional CENSYS_ORG_ID for Starter/Search/Core.
# CENSYS_API_TOKEN=
# CENSYS_PAT=
# CENSYS_ORG_ID=
#
# VirusTotal — domain reputation / detection stats
# https://www.virustotal.com/gui/my-apikey
# VIRUSTOTAL_API_KEY=
#
# NVD (NIST) — required for reliable CVE enrichment (free key)
# https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=
# EPSS (FIRST.org) — exploit probability; no API key required
#
# Have I Been Pwned — required for reliable breach history
# https://haveibeenpwned.com/API/Key
# HIBP_API_KEY=

# --- ILL Threat Intel (Internet Leased Line — NSP edge) ---
ILL_THREAT_ENABLED=true
ILL_INSPECTION_METHOD=hybrid_dpi_dns
ILL_DEFAULT_FAIL_MODE=fail_open
# Required for /api/v1 ILL gateway routes (empty = all gateway auth rejected)
ILL_API_GATEWAY_KEY=
ILL_CACHE_TTL_SECONDS=900
ILL_SYNC_INTERVAL_MINUTES=10
ILL_GATEWAY_RATE_LIMIT=1000
ILL_CLOUD_REGION=ap-south-1

# --- Scheduled jobs ---
# CRON_SECRET=  # Authorization: Bearer <secret> or X-Cron-Secret for GET /api/cycles/reminders

# --- Jira (Assurance — open vulnerability tracking) ---
# When unset, Assurance pages show clearly marked demo data.
# Required: personal API token from https://id.atlassian.com/manage-profile/security/api-tokens
# (Basic auth: email + token). Not sufficient: Organization API key from admin.atlassian.com (even with org id).
# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=you@example.com
# # Or: JIRA_USER=you@example.com
# JIRA_API_TOKEN=
# # JIRA_ORG_ID=  # optional note only — org id is NOT used for Jira issue Basic auth
# JIRA_PROJECT_KEY=SEC
# Optional global JQL (defaults to unresolved issues with sast|dast|infra|cloud labels):
# JIRA_JQL=
# Optional per-source JQL overrides (preferred when projects/labels differ):
# JIRA_JQL_SAST=project = SEC AND statusCategory != Done AND labels = sast
# JIRA_JQL_DAST=project = SEC AND statusCategory != Done AND labels = dast
# JIRA_JQL_INFRA=project = SEC AND statusCategory != Done AND labels in (infra, infrastructure, vm)
# JIRA_JQL_CLOUD=project = SEC AND statusCategory != Done AND labels in (cloud, cspm)
# Classification: labels (sast|dast|infra|infrastructure|cloud|vm|cspm), else summary prefixes [SAST]/[DAST]/[VM]/[CLOUD]
