# PostgreSQL (local Docker — see docker-compose.yml)
DATABASE_URL="postgresql://grc:grc_dev_password@localhost:5432/grc_platform?schema=public"

# AI Copilot — pick a provider: openai | ollama | groq
AI_ENABLED=true
AI_PROVIDER=ollama

# --- Option A: Ollama (FREE, local — no API key needed) ---
# 1. Install from https://ollama.com
# 2. Run: ollama pull llama3.2
# 3. Use settings below (defaults work)
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=llama3.2
# OPENAI_API_KEY not required for Ollama

# --- Option B: Groq (FREE tier — get key at https://console.groq.com) ---
# AI_PROVIDER=groq
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.1-8b-instant

# --- Option C: OpenAI (paid API — ChatGPT Go subscription does NOT include this) ---
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Google Chronicle / SecOps (optional)
CHRONICLE_ENABLED=false
CHRONICLE_GCP_PROJECT_ID=
CHRONICLE_INSTANCE=
CHRONICLE_REGION=us
GOOGLE_APPLICATION_CREDENTIALS=

# --- Contact form email (submissions go to tech@propelreadysolutions.in) ---
CONTACT_INQUIRY_TO=tech@propelreadysolutions.in
CONTACT_INQUIRY_FROM="Propel Ready Website <noreply@propelreadysolutions.in>"
# Uses FormSubmit relay by default when Resend/SMTP are not set (first email needs inbox activation).
# Set to false to require RESEND_API_KEY or SMTP_HOST instead.
# CONTACT_USE_FORMSUBMIT=false

# Option A: Resend (https://resend.com) — verify your domain, then set API key
# RESEND_API_KEY=re_...

# Option B: SMTP (e.g. Google Workspace / Zoho for propelreadysolutions.in)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# --- AWS lab monitoring (read-only IAM user or role) ---
AWS_MONITOR_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Azure lab monitoring (service principal with Reader + Security Reader) ---
AZURE_MONITOR_ENABLED=false
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
